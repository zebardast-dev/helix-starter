{
  "name": "helix/starter",
  "description": "Helix WordPress Theme Starter",
  "type": "project",
  "require": {
    "php": "^8.1",
    "helix/framework": "^1.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../helix-framework",
      "options": {
        "symlink": true
      }
    }
  ],
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist"
  }
}
