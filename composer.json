{
  "name": "zebardast-dev/helix-starter",
  "description": "Helix WordPress Theme Starter",
  "type": "project",
  "require": {
    "php": "^8.1",
    "zebardast-dev/helix-framework": "^1.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist"
  }
}
