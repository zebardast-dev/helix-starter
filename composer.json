{
  "name": "helix/starter",
  "description": "Helix WordPress Theme Starter",
  "type": "project",
  "require": {
    "php": "^8.1",
    "helix/framework": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
