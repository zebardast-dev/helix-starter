#!/usr/bin/env php
<?php

// Find WordPress root by walking up the directory tree
$wpRoot = (function () {
    $dir = __DIR__;
    while ($dir !== dirname($dir)) {
        if (file_exists($dir . '/wp-load.php')) {
            return $dir;
        }
        $dir = dirname($dir);
    }
    return null;
})();

if (!$wpRoot) {
    fwrite(STDERR, "\033[31m  Error:\033[0m WordPress installation not found.\n");
    exit(1);
}

// Minimal HTTP context so WordPress does not redirect
$_SERVER += [
    'HTTP_HOST'      => 'localhost',
    'REQUEST_URI'    => '/',
    'REQUEST_METHOD' => 'GET',
    'SERVER_NAME'    => 'localhost',
    'SERVER_PORT'    => '80',
];

// wp-load.php boots WordPress and triggers functions.php → Framework::create()
require_once $wpRoot . '/wp-load.php';

// Register any project-specific commands defined in core/commands.php
$kernel = new Helix\Console\Kernel($argv);

$commandsFile = __DIR__ . '/core/commands.php';
if (file_exists($commandsFile)) {
    $kernel->register_many(require $commandsFile);
}

exit($kernel->run());
